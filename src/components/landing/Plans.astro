---
interface Props {
  title?: string;
  description?: string;
}

const { 
  title = "Inversión", 
  description = "Todo listo para que comiences hoy mismo" 
} = Astro.props;
---

<section id="inversion" class="py-20 bg-black relative overflow-hidden">
  <!-- Background Image from january folder -->
  <div class="absolute inset-0 z-0">
    <img 
      src="/assets/january/Fotos/IMG_4808.JPG" 
      alt="Background" 
      class="w-full h-full object-cover opacity-20"
    />
    <div class="absolute inset-0 bg-black/80"></div>
  </div>

  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <!-- Section Header -->
    <div class="text-center mb-16">
      <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold text-white mb-6">
        {title}
      </h2>
      <p class="text-xl text-white/80 max-w-3xl mx-auto leading-relaxed">
        {description}
      </p>
    </div>

    <!-- Pricing Grid -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 items-start">
      <!-- Card 1 -->
      <div class="bg-white rounded-2xl p-8 shadow-2xl border-2 border-primary transform md:scale-105 relative z-10">
        <div class="absolute -top-4 left-1/2 -translate-x-1/2 bg-primary text-white px-4 py-1 rounded-full text-xs font-bold whitespace-nowrap">
          OFERTA ACTUAL
        </div>
        
        <div class="text-center">
          <h3 class="text-2xl font-bold text-text-dark mb-2">Fase 1</h3>
          <p class="text-xs font-semibold text-primary mb-4">Beneficio reservado para la comunidad</p>
          <p class="text-sm text-gray-500 mb-6 font-bold underline">27/01 al 29/01</p>
          
          <div class="space-y-4 mb-8 text-left text-sm">
            <div class="flex items-start">
              <span class="mr-2">✔️</span>
              <span class="text-text-dark">7 módulos grabados para avanzar a tu ritmo</span>
            </div>
            <div class="flex items-start">
              <span class="mr-2">✔️</span>
              <span class="text-text-dark">2 videos bonus exclusivos incluidos</span>
            </div>
            <div class="flex items-start">
              <span class="mr-2">✔️</span>
              <span class="text-text-dark">Material descargable para aplicar desde el día uno</span>
            </div>
            <div class="flex items-start">
              <span class="mr-2">✔️</span>
              <span class="text-text-dark">30 días de acompañamiento exclusivo por WhatsApp, con cupos limitados: no todas logran ser parte</span>
            </div>
          </div>

          <!-- Countdown Timer -->
          <div class="mb-6 bg-gray-900 text-white px-4 py-3 rounded-xl shadow-inner border border-primary/20 flex flex-col items-center gap-1">
            <span class="text-[10px] uppercase tracking-widest text-primary font-bold">La oferta cierra en:</span>
            <div class="flex gap-1 font-mono text-lg font-bold" id="countdown-fase1">
              <span id="days">00</span><span class="text-xs opacity-70 mr-1">d</span>
              <span class="opacity-30">:</span>
              <span id="hours">00</span><span class="text-xs opacity-70 mr-1">h</span>
              <span class="opacity-30">:</span>
              <span id="minutes">00</span><span class="text-xs opacity-70 mr-1">m</span>
              <span class="opacity-30">:</span>
              <span id="seconds">00</span><span class="text-xs opacity-70">s</span>
            </div>
          </div>
          
          <a 
            href="https://pay.hotmart.com/Y103097499K?off=wz362e0a" 
            target="_blank"
            class="block w-full py-4 bg-primary text-white rounded-full font-bold hover:bg-red-dark transition-all duration-300 shadow-lg"
          >
            QUIERO MI LUGAR
          </a>
        </div>
      </div>

      <!-- Card 2 -->
      <div class="bg-gray-100 rounded-2xl p-6 shadow-xl border-2 border-gray-300 relative opacity-75">
        <div class="absolute inset-0 z-10 bg-white/40 rounded-2xl flex items-center justify-center">
          <span class="bg-gray-800 text-white px-4 py-2 rounded-lg font-bold rotate-12">PRÓXIMAMENTE</span>
        </div>
        <div class="text-center">
          <h3 class="text-xl font-bold text-gray-600 mb-2">Fase 2</h3>
          <p class="text-xs font-semibold text-gray-500 mb-4 uppercase tracking-widest">Oportunidad disponible por 24 horas</p>
          <p class="text-sm text-gray-500 mb-6 font-bold underline">29/01 al 30/01</p>
          
          <div class="space-y-3 mb-8 text-left text-sm">
            <div class="flex items-start">
              <span class="mr-2">✔️</span>
              <span class="text-gray-600">7 módulos grabados para avanzar a tu ritmo</span>
            </div>
            <div class="flex items-start">
              <span class="mr-2">✔️</span>
              <span class="text-gray-600">2 videos bonus exclusivos incluidos</span>
            </div>
            <div class="flex items-start">
              <span class="mr-2">✔️</span>
              <span class="text-gray-600">Material descargable para aplicar desde el día uno</span>
            </div>
            <div class="flex items-start">
              <span class="mr-2">✔️</span>
              <span class="text-gray-600">30 días de acompañamiento exclusivo por WhatsApp, con cupos limitados: no todas logran ser parte</span>
            </div>
          </div>
          
          <button disabled class="w-full py-3 bg-gray-400 text-white rounded-full font-bold cursor-not-allowed">
            Cerrado
          </button>
        </div>
      </div>

      <!-- Card 3 -->
      <div class="bg-gray-100 rounded-2xl p-6 shadow-xl border-2 border-gray-300 relative opacity-75">
        <div class="absolute inset-0 z-10 bg-white/40 rounded-2xl flex items-center justify-center">
          <span class="bg-gray-800 text-white px-4 py-2 rounded-lg font-bold rotate-12">PRÓXIMAMENTE</span>
        </div>
        <div class="text-center">
          <h3 class="text-xl font-bold text-gray-600 mb-2">Fase 3</h3>
          <p class="text-xs font-semibold text-gray-500 mb-4 uppercase tracking-widest">Oportunidad disponible por 24 horas</p>
          <p class="text-sm text-gray-500 mb-6 font-bold underline">30/01 al 31/01</p>
          
          <div class="space-y-3 mb-8 text-left text-sm">
            <div class="flex items-start">
              <span class="mr-2">✔️</span>
              <span class="text-gray-600">7 módulos grabados para avanzar a tu ritmo</span>
            </div>
            <div class="flex items-start">
              <span class="mr-2">✔️</span>
              <span class="text-gray-600">2 videos bonus exclusivos incluidos</span>
            </div>
            <div class="flex items-start">
              <span class="mr-2">✔️</span>
              <span class="text-gray-600">Material descargable para aplicar desde el día uno</span>
            </div>
            <div class="flex items-start">
              <span class="mr-2">✔️</span>
              <span class="text-gray-600">30 días de acompañamiento exclusivo por WhatsApp, con cupos limitados: no todas logran ser parte</span>
            </div>
          </div>
          
          <button disabled class="w-full py-3 bg-gray-400 text-white rounded-full font-bold cursor-not-allowed">
            Cerrado
          </button>
        </div>
      </div>
    </div>

  </div>
</section>

<script>
  // Countdown Timer for Fase 1
  function updateCountdown() {
    const targetDate = new Date('January 29, 2026 00:00:00').getTime();
    const now = new Date().getTime();
    const distance = targetDate - now;

    const container = document.getElementById('countdown-fase1');
    if (distance < 0) {
      if (container) container.innerHTML = "<span class='text-primary font-bold'>CERRADO</span>";
      return;
    }

    const days = Math.floor(distance / (1000 * 60 * 60 * 24));
    const hours = Math.floor((distance % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
    const minutes = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60));
    const seconds = Math.floor((distance % (1000 * 60)) / 1000);

    const daysEl = document.querySelector('#countdown-fase1 #days');
    const hoursEl = document.querySelector('#countdown-fase1 #hours');
    const minutesEl = document.querySelector('#countdown-fase1 #minutes');
    const secondsEl = document.querySelector('#countdown-fase1 #seconds');

    if (daysEl) daysEl.textContent = days.toString().padStart(2, '0');
    if (hoursEl) hoursEl.textContent = hours.toString().padStart(2, '0');
    if (minutesEl) minutesEl.textContent = minutes.toString().padStart(2, '0');
    if (secondsEl) secondsEl.textContent = seconds.toString().padStart(2, '0');
  }

  setInterval(updateCountdown, 1000);
  updateCountdown();
</script> 