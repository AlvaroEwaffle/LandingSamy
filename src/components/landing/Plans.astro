---
import {
  activeOffer,
  launchNarrative,
  offerPhases,
  upcomingOffer,
  waitlistLink,
} from '../../data/offerPhases';

interface Props {
  title?: string;
}

const {
  title = 'Inversión',
} = Astro.props;
---

<section id="inversion" class="relative overflow-hidden bg-black py-20">
  <div class="absolute inset-0 z-0">
    <div class="absolute inset-0 bg-black"></div>
  </div>

  <div class="relative z-10 mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
    <div class="mx-auto mb-14 max-w-5xl text-center">
      <p class="mb-4 text-sm font-semibold uppercase tracking-[0.32em] text-primary/90 md:text-base">
        Ventana de beneficios
      </p>
      <h2 class="text-3xl font-extrabold leading-tight text-white md:text-5xl">
        {title}
      </h2>
      <p class="mt-6 text-lg leading-relaxed text-white/80 md:text-xl">
        {launchNarrative}
      </p>
    </div>

    <div class="grid grid-cols-1 items-stretch gap-3 lg:grid-cols-3">
      {offerPhases.map((phase) => {
        const isActive = phase.status === 'active';
        const isClosed = phase.status === 'closed';
        const isUnavailable = phase.status !== 'active';
        const isNextUpcoming = !activeOffer && upcomingOffer?.id === phase.id;
        const showCountdownByDefault = isActive || isNextUpcoming;
        const upcomingNote = phase.availabilityNote ?? 'Esta caja se activa cuando cierre la oferta anterior.';

        return (
          <article
            data-phase-card
            data-default-state={phase.status}
            data-start-at={phase.startAt ?? ''}
            data-end-at={phase.endAt ?? ''}
            class:list={[
              'phase-card relative flex h-full min-h-[31rem] overflow-hidden rounded-[1.75rem] border p-4 backdrop-blur-sm transition-all duration-300 md:min-h-[32.5rem] md:p-5',
              isActive
                ? 'border-primary bg-white text-slate-950 shadow-[0_24px_80px_rgba(210,32,31,0.28)]'
                : 'border-white/15 bg-black/65 text-white',
              phase.status === 'upcoming' && 'opacity-95',
              isClosed && 'opacity-60 grayscale',
            ]}
          >
            <div
              data-phase-closed-badge
              class:list={[
                'absolute right-5 top-5 rounded-full bg-primary px-4 py-2 text-xs font-black uppercase tracking-[0.28em] text-white',
                !isClosed && 'hidden',
              ]}
            >
              Sold Out
            </div>

            <div class="flex h-full w-full flex-col">
              <div class="phase-main">
                <div class="flex flex-col gap-2 lg:flex-row lg:items-start lg:justify-between">
                  <div>
                    <p class:list={[
                    'phase-label text-[11px] font-black uppercase tracking-[0.28em]',
                    isActive ? 'text-primary' : 'text-white/80',
                  ]}>
                    {phase.label}
                  </p>
                  <h3 class:list={[
                    'phase-title mt-1.5 text-[1.7rem] font-black leading-[0.98] md:text-[1.85rem]',
                    isActive ? 'text-slate-950' : 'text-white',
                  ]}>
                    {phase.title}
                    </h3>
                  </div>
                  <span class:list={[
                    'phase-status-pill inline-flex max-w-full w-fit shrink-0 rounded-full px-2.5 py-1.5 text-[9px] font-black uppercase tracking-[0.1em] md:px-3 md:py-2 md:text-[10px]',
                    isActive && 'bg-primary/10 text-primary',
                    phase.status === 'upcoming' && 'bg-white/10 text-white/70',
                    isClosed && 'bg-white/10 text-white/70',
                  ]}>
                    {isActive ? 'Disponible ahora' : isClosed ? 'Cerrado' : 'Próximamente'}
                  </span>
                </div>

                <p class:list={[
                  'phase-description mt-3 text-sm leading-relaxed md:text-[15px]',
                  isActive ? 'text-slate-600' : 'text-white/88',
                ]}>
                  {phase.description}
                </p>

                <div class="phase-price-block mt-4">
                  <div class:list={[
                    'phase-price text-[3.45rem] font-black tracking-tight md:text-[4rem]',
                    isActive ? 'text-slate-950' : 'text-white',
                  ]}>
                    ${phase.priceUsd} <span class="text-lg font-bold md:text-xl">USD</span>
                  </div>
                  <p class:list={[
                    'phase-discount mt-1.5 text-sm font-semibold uppercase tracking-[0.22em]',
                    isActive ? 'text-primary' : 'text-white/80',
                  ]}>
                    {phase.discountLabel}
                  </p>
                  <p class:list={[
                    'phase-savings mt-1.5 text-sm',
                    isActive ? 'text-slate-500' : 'text-white/80',
                  ]}>
                    {phase.savingsText}
                  </p>
                </div>
              </div>

              <div class="phase-bottom mt-auto pt-4">
                <div class="space-y-3">
                  {(phase.startAt || phase.countdownTarget) && (
                    <div
                      class:list={[
                        'phase-countdown-card rounded-2xl border border-primary/20 bg-primary/12 p-3 text-center',
                        !showCountdownByDefault && 'hidden',
                      ]}
                      data-countdown-card
                      data-countdown-start-at={phase.startAt ?? ''}
                      data-countdown-end-at={phase.endAt ?? phase.countdownTarget ?? ''}
                    >
                      <p class="phase-countdown-label text-[11px] font-black uppercase tracking-[0.2em] text-primary">
                        {isNextUpcoming ? 'Se activa en' : 'Tiempo restante de esta oferta'}
                      </p>
                      <p
                        class="phase-countdown-value mt-2 text-[2.45rem] font-black tabular-nums tracking-[0.04em] text-white"
                        data-countdown-target={phase.countdownTarget ?? phase.startAt}
                      >
                        00:00:00
                      </p>
                    </div>
                  )}

                  <p
                    class:list={[
                      'phase-upcoming-note text-[11px] font-semibold uppercase tracking-[0.12em] text-white/75',
                      phase.status !== 'upcoming' && 'hidden',
                    ]}
                  >
                      {upcomingNote}
                  </p>
                </div>

                <div class="mt-4">
                  <a
                    href={phase.ctaHref ?? '#'}
                    target="_blank"
                    rel="noopener noreferrer"
                    data-phase-button
                    data-disabled={isUnavailable ? 'true' : 'false'}
                    class="phase-button inline-flex w-full items-center justify-center rounded-full px-5 py-2.5 text-center text-sm font-black transition-all duration-300"
                  >
                    {phase.ctaLabel}
                  </a>
                </div>
              </div>
            </div>
          </article>
        );
      })}
    </div>

    <div id="plans-soldout-card" class="mx-auto mt-10 hidden max-w-4xl">
        <div class="rounded-[2rem] border border-white/10 bg-white/5 p-8 text-center backdrop-blur-sm">
          <h3 class="text-3xl font-extrabold text-white">
            SOLD OUT
          </h3>
          <p class="mt-4 text-lg leading-relaxed text-white/80">
            Las inscripciones ya cerraron. Si quieres ser la primera en enterarte cuando vuelva a abrir, súmate a la lista de espera.
          </p>
          <a
            href={waitlistLink}
            target="_blank"
            rel="noopener noreferrer"
            class="mt-8 inline-flex items-center justify-center rounded-full bg-primary px-8 py-4 text-sm font-black uppercase tracking-[0.14em] text-white transition-all duration-300 hover:-translate-y-1 hover:bg-red-dark"
          >
            No me lo quiero volver a perder
          </a>
        </div>
      </div>
  </div>
</section>

<script is:inline>
  (function () {
    function resolvePhaseState(startAt, endAt, fallbackState) {
      if (!startAt || !endAt) {
        return fallbackState || 'upcoming';
      }

      var now = Date.now();
      var start = new Date(startAt).getTime();
      var end = new Date(endAt).getTime();

      if (now < start) return 'upcoming';
      if (now >= end) return 'closed';
      return 'active';
    }

    function pad2(value) {
      return String(value).padStart(2, '0');
    }

    function formatCountdown(ms) {
      var totalSeconds = Math.max(0, Math.floor(ms / 1000));
      var days = Math.floor(totalSeconds / 86400);
      var hours = Math.floor(totalSeconds / 3600);
      var minutes = Math.floor((totalSeconds % 3600) / 60);
      var seconds = totalSeconds % 60;

      if (days > 0) {
        return days + 'd ' + pad2(hours % 24) + ':' + pad2(minutes) + ':' + pad2(seconds);
      }

      return pad2(hours) + ':' + pad2(minutes) + ':' + pad2(seconds);
    }

    function updateCountdowns() {
      document.querySelectorAll('[data-countdown-card]').forEach(function (card) {
        if (!(card instanceof HTMLElement)) return;

        var phaseCard = card.closest('[data-phase-card]');
        var valueEl = card.querySelector('[data-countdown-target]');
        var labelEl = card.querySelector('.phase-countdown-label');
        if (!(phaseCard instanceof HTMLElement) || !(valueEl instanceof HTMLElement) || !(labelEl instanceof HTMLElement)) {
          return;
        }

        var state = phaseCard.dataset.state;
        var startAt = card.getAttribute('data-countdown-start-at');
        var endAt = card.getAttribute('data-countdown-end-at');
        var target = state === 'upcoming' ? startAt : state === 'active' ? endAt : '';

        if (!target) {
          card.classList.add('hidden');
          return;
        }

        var remaining = new Date(target).getTime() - Date.now();

        if (remaining <= 0 || state === 'closed') {
          card.classList.add('hidden');
          return;
        }

        labelEl.textContent = state === 'upcoming'
          ? 'Se activa en'
          : 'Tiempo restante de esta oferta';
        valueEl.textContent = formatCountdown(remaining);
        card.classList.remove('hidden');
      });
    }

    function updatePhaseCards() {
      var cards = document.querySelectorAll('[data-phase-card]');
      var allClosed = cards.length > 0;

      var activeCard = null;
      var nextUpcomingCard = null;

      cards.forEach(function (card) {
        if (!(card instanceof HTMLElement)) return;

        var state = resolvePhaseState(
          card.getAttribute('data-start-at'),
          card.getAttribute('data-end-at'),
          card.getAttribute('data-default-state')
        );

        if (state !== 'closed') {
          allClosed = false;
        }

        card.dataset.state = state;

        if (state === 'active' && !activeCard) {
          activeCard = card;
        }

        if (state === 'upcoming' && !nextUpcomingCard) {
          nextUpcomingCard = card;
        }

        card.classList.toggle('opacity-95', state === 'upcoming');
        card.classList.toggle('opacity-60', state === 'closed');
        card.classList.remove('opacity-55', 'opacity-45');
        card.classList.toggle('grayscale', state === 'closed');

        var pill = card.querySelector('.phase-status-pill');
        if (pill) {
          pill.textContent = state === 'active' ? 'Disponible ahora' : state === 'closed' ? 'Cerrado' : 'Próximamente';
        }

        var button = card.querySelector('[data-phase-button]');
        if (button instanceof HTMLAnchorElement) {
          var isDisabled = state !== 'active';
          button.dataset.disabled = isDisabled ? 'true' : 'false';
          button.setAttribute('aria-disabled', isDisabled ? 'true' : 'false');
          button.tabIndex = isDisabled ? -1 : 0;
        }

        var note = card.querySelector('.phase-upcoming-note');
        if (note instanceof HTMLElement) {
          note.classList.toggle('hidden', state !== 'upcoming');
        }

        var countdown = card.querySelector('[data-countdown-card]');
        if (countdown instanceof HTMLElement) {
          countdown.dataset.visible = 'false';
        }

        var soldOutBadge = card.querySelector('[data-phase-closed-badge]');
        if (soldOutBadge instanceof HTMLElement) {
          soldOutBadge.classList.toggle('hidden', state !== 'closed');
        }
      });

      cards.forEach(function (card) {
        if (!(card instanceof HTMLElement)) return;

        var countdown = card.querySelector('[data-countdown-card]');
        if (!(countdown instanceof HTMLElement)) return;

        var state = card.dataset.state;
        var shouldShowCountdown =
          (state === 'active' && card === activeCard) ||
          (!activeCard && state === 'upcoming' && card === nextUpcomingCard);

        countdown.dataset.visible = shouldShowCountdown ? 'true' : 'false';
        countdown.classList.toggle('hidden', !shouldShowCountdown);
      });

      var soldOutCard = document.getElementById('plans-soldout-card');
      if (soldOutCard instanceof HTMLElement) {
        soldOutCard.classList.toggle('hidden', !allClosed);
      }
    }

    function run() {
      updatePhaseCards();
      updateCountdowns();

      if (document.querySelector('[data-countdown-target]')) {
        window.setInterval(function () {
          updatePhaseCards();
          updateCountdowns();
        }, 1000);
      }
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', run);
    } else {
      run();
    }
  })();
</script>

<style>
  .phase-main {
    display: flex;
    flex-direction: column;
  }

  .phase-card[data-state='active'] {
    border-color: rgba(210, 32, 31, 1);
    background: rgba(255, 255, 255, 0.98);
    color: rgb(15 23 42);
    box-shadow: 0 24px 80px rgba(210, 32, 31, 0.28);
  }

  .phase-card[data-state='active'] .phase-label,
  .phase-card[data-state='active'] .phase-discount,
  .phase-card[data-state='active'] .phase-status-pill {
    color: rgb(210 32 31);
  }

  .phase-card[data-state='active'] .phase-status-pill {
    background: rgba(210, 32, 31, 0.1);
  }

  .phase-card[data-state='active'] .phase-title,
  .phase-card[data-state='active'] .phase-price {
    color: rgb(15 23 42);
  }

  .phase-card[data-state='active'] .phase-description,
  .phase-card[data-state='active'] .phase-savings {
    color: rgb(71 85 105);
  }

  .phase-card[data-state='active'] .phase-countdown-value {
    color: rgb(15 23 42);
  }

  .phase-card[data-state='upcoming'] .phase-label,
  .phase-card[data-state='upcoming'] .phase-discount,
  .phase-card[data-state='closed'] .phase-label,
  .phase-card[data-state='closed'] .phase-discount {
    color: rgba(255, 90, 90, 0.95);
  }

  .phase-card[data-state='upcoming'],
  .phase-card[data-state='closed'] {
    background:
      linear-gradient(180deg, rgba(210, 32, 31, 0.12) 0%, rgba(12, 12, 12, 0.92) 22%, rgba(8, 8, 8, 0.96) 100%);
    border-color: rgba(210, 32, 31, 0.38);
    box-shadow: 0 16px 40px rgba(210, 32, 31, 0.12);
  }

  .phase-card[data-state='upcoming'] .phase-status-pill,
  .phase-card[data-state='closed'] .phase-status-pill {
    background: rgba(210, 32, 31, 0.95);
    color: white;
    border: 1px solid rgba(255, 255, 255, 0.08);
  }

  .phase-button[data-disabled='true'] {
    pointer-events: none;
    cursor: not-allowed;
    background: rgba(210, 32, 31, 0.1);
    border: 1px solid rgba(210, 32, 31, 0.4);
    color: rgba(255, 255, 255, 0.82);
    transform: none;
    box-shadow: none;
  }

  .phase-button[data-disabled='false'] {
    cursor: pointer;
    background: rgb(210 32 31);
    color: white;
    border: 1px solid transparent;
  }

  .phase-button[data-disabled='false']:hover {
    transform: translateY(-4px);
    background: rgb(185 28 28);
  }

  @media (min-width: 1024px) {
    .phase-title {
      min-height: 5.9rem;
      max-width: 10ch;
    }

    .phase-description {
      min-height: 6.8rem;
    }

    .phase-price-block {
      min-height: 7rem;
    }

    .phase-status-pill {
      margin-top: 0.15rem;
      white-space: nowrap;
    }
  }
</style>
