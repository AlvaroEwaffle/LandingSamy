---
interface Props {
  title?: string;
}

const { 
  title = "Inversión"
} = Astro.props;

const waitlistLink =
  "https://chat.whatsapp.com/CIhFvZC60A662j6QGuxiNs?mode=gi_t";

const phase2CheckoutLink = "https://pay.hotmart.com/Y103097499K?off=zi9wfqaz";
---

<section id="inversion" class="py-20 bg-black relative overflow-hidden">
  <!-- Background Image from january folder -->
  <div class="absolute inset-0 z-0">
    <img 
      src="/assets/january/Fotos/IMG_4808.JPG" 
      alt="Background" 
      class="w-full h-full object-cover opacity-20"
    />
    <div class="absolute inset-0 bg-black/80"></div>
  </div>

  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <!-- SOLD OUT (default: ahora y después de Fase 2) -->
    <div id="plans-soldout">
      <div class="max-w-4xl mx-auto">
        <div class="rounded-3xl border border-white/10 bg-white/5 backdrop-blur-sm shadow-2xl overflow-hidden">
          <div class="p-8 md:p-12 text-center">
            <h2 class="text-3xl md:text-5xl font-extrabold text-white leading-tight">
              SOLD OUT
            </h2>

            <p class="mt-6 text-lg md:text-xl text-white/85 leading-relaxed">
              <span class="font-semibold">De verdad, gracias.</span><br />
              El acceso a nuestra formación se agotó en solo 4 días y eso me tiene profundamente agradecida por la confianza.
            </p>

            <p class="mt-6 text-lg md:text-xl text-white/85 leading-relaxed">
              Si esta vez no alcanzaste tu cupo, abrí una lista de espera para que seas la primera en enterarte cuando vuelva a abrir.
            </p>

            <div class="mt-10">
              <a
                href={waitlistLink}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center justify-center px-8 py-4 bg-primary text-white rounded-full font-bold text-lg hover:bg-red-dark transition-all duration-300 shadow-lg hover:shadow-xl transform hover:-translate-y-1"
              >
                No me lo quiero volver a perder
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- FASE 2: solo durante la ventana de reapertura (07/02 21:59 → 08/02 12:00 Chile) -->
    <div id="plans-phase2" class="hidden">
      <div class="max-w-4xl mx-auto">
        <div class="rounded-3xl border border-white/10 bg-white/5 backdrop-blur-sm shadow-2xl overflow-hidden">
          <div class="p-8 md:p-12 text-center">
            <h2 class="text-3xl md:text-5xl font-extrabold text-white leading-tight">
              Hay una nueva oportunidad
            </h2>
            <p class="mt-6 text-lg md:text-xl text-white/85 leading-relaxed">
              Hicimos SOLD OUT en 4 días. No te quedes fuera otra vez.
            </p>

            <div class="mt-8 flex items-baseline justify-center gap-2">
              <span class="text-5xl md:text-6xl font-extrabold text-primary">147</span>
              <span class="text-xl md:text-2xl text-white/70 font-bold">USD</span>
            </div>
            <p class="mt-3 text-sm text-white/70">
              Disponible hasta el 08/02 23:59 (hora Chile)
            </p>

            <div class="mt-10">
              <a
                href={phase2CheckoutLink}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center justify-center px-10 py-4 bg-primary text-white rounded-full font-bold text-lg hover:bg-red-dark transition-all duration-300 shadow-lg hover:shadow-xl transform hover:-translate-y-1"
              >
                QUIERO ACCEDER
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>

  </div>
</section>

<script is:inline>
  (function () {
    // Chile UTC-3 en feb. Usamos UTC para que cambie igual en todo el mundo.
    // Fase 2 empieza: 07/02 21:59 Chile = 08/02 00:59Z
    // Fase 2 termina: 08/02 23:59 Chile = 09/02 02:59Z
    var PHASE2_START_AT = new Date('2026-02-08T00:59:00Z');
    var PHASE2_END_AT = new Date('2026-02-09T02:59:00Z'); // 08/02 23:59 Chile

    function getPhase() {
      var now = new Date();
      if (now >= PHASE2_START_AT && now < PHASE2_END_AT) return 2;
      return 'soldout';
    }

    function showOnly(idToShow) {
      var soldout = document.getElementById('plans-soldout');
      var phase2 = document.getElementById('plans-phase2');
      if (!soldout || !phase2) return;
      if (idToShow === 'plans-phase2') {
        soldout.classList.add('hidden');
        phase2.classList.remove('hidden');
      } else {
        soldout.classList.remove('hidden');
        phase2.classList.add('hidden');
      }
    }

    function tick() {
      var phase = getPhase();
      if (phase === 2) showOnly('plans-phase2');
      else showOnly('plans-soldout');
    }

    function run() { tick(); setInterval(tick, 1000); }
    if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', run);
    else run();
  })();
</script>