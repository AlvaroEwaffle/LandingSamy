<script is:inline>
  (function () {
    // 00:00 Chile (UTC-3) → 03:00 UTC
    var FASE2_OPENS_AT = new Date('2026-01-29T03:00:00Z');
    var FASE3_OPENS_AT = new Date('2026-01-30T03:00:00Z');
    var FASE3_CLOSES_AT = new Date('2026-01-31T03:00:00Z');

    function getActivePhase() {
      var now = new Date();
      if (now < FASE2_OPENS_AT) return 1;
      if (now < FASE3_OPENS_AT) return 2;
      if (now < FASE3_CLOSES_AT) return 3;
      return 'closed';
    }

    function pad2(n) { return String(n).padStart(2, '0'); }

    function updateCountdown(targetDate, opts) {
      var now = Date.now();
      var distance = targetDate.getTime() - now;
      var countdownEl = opts.countdownEl;
      var ids = opts.ids;
      if (!countdownEl || !ids) return;
      if (distance < 0) {
        countdownEl.innerHTML = "<span class='text-primary font-bold'>CERRADO</span>";
        return;
      }
      var days = Math.floor(distance / 864e5);
      var hours = Math.floor((distance % 864e5) / 36e5);
      var minutes = Math.floor((distance % 36e5) / 6e4);
      var seconds = Math.floor((distance % 6e4) / 1e3);
      var d = document.getElementById(ids.days);
      var h = document.getElementById(ids.hours);
      var m = document.getElementById(ids.minutes);
      var s = document.getElementById(ids.seconds);
      if (d) d.textContent = pad2(days);
      if (h) h.textContent = pad2(hours);
      if (m) m.textContent = pad2(minutes);
      if (s) s.textContent = pad2(seconds);
    }

    function applyPhaseState(phase) {
      var phase1 = phase === 1;
      var phase2 = phase === 2;
      var phase3 = phase === 3;
      var allClosed = phase === 'closed';

      var card1 = document.getElementById('card-fase1');
      var badge1 = document.getElementById('fase1-badge');
      var overlay1 = document.getElementById('fase1-closed-overlay');
      var countdown1Wrap = document.getElementById('fase1-countdown-wrap');
      var ctaLink1 = document.getElementById('fase1-cta-link');
      var ctaClosed1 = document.getElementById('fase1-cta-closed');

      var card2 = document.getElementById('card-fase2');
      var overlay2 = document.getElementById('fase2-overlay');
      var badge2 = document.getElementById('fase2-badge-wrap');
      var price2 = document.getElementById('fase2-price-wrap');
      var countdown2Wrap = document.getElementById('fase2-countdown-wrap');
      var ctaClosed2 = document.getElementById('fase2-cta-closed');
      var ctaLink2 = document.getElementById('fase2-cta-link');

      var card3 = document.getElementById('card-fase3');
      var overlay3Prox = document.getElementById('fase3-overlay-prox');
      var overlay3Closed = document.getElementById('fase3-overlay-closed');
      var badge3 = document.getElementById('fase3-badge-wrap');
      var price3 = document.getElementById('fase3-price-wrap');
      var countdown3Wrap = document.getElementById('fase3-countdown-wrap');
      var ctaClosed3 = document.getElementById('fase3-cta-closed');
      var ctaLink3 = document.getElementById('fase3-cta-link');

      if (phase1) {
        if (card1) { card1.classList.remove('bg-gray-100','opacity-75','md:scale-100','border-gray-300'); card1.classList.add('bg-white','md:scale-105','border-primary'); }
        if (badge1) badge1.classList.remove('hidden');
        if (overlay1) overlay1.classList.add('hidden');
        if (countdown1Wrap) countdown1Wrap.classList.remove('hidden');
        if (ctaLink1) { ctaLink1.classList.remove('hidden'); ctaLink1.style.display = 'block'; }
        if (ctaClosed1) { ctaClosed1.classList.add('hidden'); ctaClosed1.style.display = 'none'; }
      } else {
        if (card1) { card1.classList.remove('bg-white','md:scale-105','border-primary'); card1.classList.add('bg-gray-100','opacity-75','md:scale-100','border-gray-300'); }
        if (badge1) badge1.classList.add('hidden');
        if (overlay1) overlay1.classList.remove('hidden');
        if (countdown1Wrap) countdown1Wrap.classList.add('hidden');
        if (ctaLink1) { ctaLink1.classList.add('hidden'); ctaLink1.style.display = 'none'; }
        if (ctaClosed1) { ctaClosed1.classList.remove('hidden'); ctaClosed1.style.display = 'block'; }
      }

      if (phase2) {
        if (card2) { card2.classList.remove('bg-gray-100','opacity-75','border-gray-300'); card2.classList.add('bg-white','border-primary','md:scale-105','relative','z-10'); card2.style.opacity = '1'; }
        if (overlay2) overlay2.classList.add('hidden');
        if (badge2) badge2.classList.remove('hidden');
        if (price2) price2.classList.remove('invisible');
        if (countdown2Wrap) countdown2Wrap.classList.remove('hidden');
        if (ctaClosed2) { ctaClosed2.classList.add('hidden'); ctaClosed2.style.display = 'none'; }
        if (ctaLink2) { ctaLink2.classList.remove('hidden'); ctaLink2.style.display = 'block'; }
      } else {
        if (card2) { card2.classList.remove('bg-white','border-primary','md:scale-105','z-10'); card2.classList.add('bg-gray-100','opacity-75','border-gray-300'); card2.style.opacity = ''; }
        if (overlay2) overlay2.classList.remove('hidden');
        if (badge2) badge2.classList.add('hidden');
        if (price2) price2.classList.add('invisible');
        if (countdown2Wrap) countdown2Wrap.classList.add('hidden');
        if (ctaClosed2) { ctaClosed2.classList.remove('hidden'); ctaClosed2.style.display = 'block'; }
        if (ctaLink2) { ctaLink2.classList.add('hidden'); ctaLink2.style.display = 'none'; }
      }

      if (phase3) {
        if (card3) { card3.classList.remove('bg-gray-100','opacity-75','border-gray-300'); card3.classList.add('bg-white','border-primary','md:scale-105','relative','z-10'); card3.style.opacity = '1'; }
        if (overlay3Prox) overlay3Prox.classList.add('hidden');
        if (overlay3Closed) overlay3Closed.classList.add('hidden');
        if (badge3) badge3.classList.remove('hidden');
        if (price3) price3.classList.remove('invisible');
        if (countdown3Wrap) countdown3Wrap.classList.remove('hidden');
        if (ctaClosed3) { ctaClosed3.classList.add('hidden'); ctaClosed3.style.display = 'none'; }
        if (ctaLink3) { ctaLink3.classList.remove('hidden'); ctaLink3.style.display = 'block'; }
      } else if (allClosed) {
        if (card3) { card3.classList.remove('bg-white','border-primary','md:scale-105','z-10'); card3.classList.add('bg-gray-100','opacity-75','border-gray-300'); card3.style.opacity = ''; }
        if (overlay3Prox) overlay3Prox.classList.add('hidden');
        if (overlay3Closed) overlay3Closed.classList.remove('hidden');
        if (badge3) badge3.classList.add('hidden');
        if (price3) price3.classList.add('invisible');
        if (countdown3Wrap) countdown3Wrap.classList.add('hidden');
        if (ctaClosed3) { ctaClosed3.classList.remove('hidden'); ctaClosed3.style.display = 'block'; }
        if (ctaLink3) { ctaLink3.classList.add('hidden'); ctaLink3.style.display = 'none'; }
      } else {
        if (card3) { card3.classList.remove('bg-white','border-primary','md:scale-105','z-10'); card3.classList.add('bg-gray-100','opacity-75','border-gray-300'); }
        if (overlay3Prox) overlay3Prox.classList.remove('hidden');
        if (overlay3Closed) overlay3Closed.classList.add('hidden');
        if (badge3) badge3.classList.add('hidden');
        if (price3) price3.classList.add('invisible');
        if (countdown3Wrap) countdown3Wrap.classList.add('hidden');
        if (ctaClosed3) { ctaClosed3.classList.remove('hidden'); ctaClosed3.style.display = 'block'; }
        if (ctaLink3) { ctaLink3.classList.add('hidden'); ctaLink3.style.display = 'none'; }
      }
    }

    function tick() {
      var phase = getActivePhase();
      applyPhaseState(phase);
      var countdown1Wrap = document.getElementById('fase1-countdown-wrap');
      var countdown2Wrap = document.getElementById('fase2-countdown-wrap');
      var countdown3Wrap = document.getElementById('fase3-countdown-wrap');
      var countdown1El = document.getElementById('countdown-fase1');
      var countdown2El = document.getElementById('countdown-fase2');
      var countdown3El = document.getElementById('countdown-fase3');
      if (phase === 1 && countdown1Wrap && !countdown1Wrap.classList.contains('hidden') && countdown1El) {
        updateCountdown(FASE2_OPENS_AT, { countdownEl: countdown1El, ids: { days: 'days', hours: 'hours', minutes: 'minutes', seconds: 'seconds' } });
      }
      if (phase === 2 && countdown2Wrap && !countdown2Wrap.classList.contains('hidden') && countdown2El) {
        updateCountdown(FASE3_OPENS_AT, { countdownEl: countdown2El, ids: { days: 'f2-days', hours: 'f2-hours', minutes: 'f2-minutes', seconds: 'f2-seconds' } });
      }
      if (phase === 3 && countdown3Wrap && !countdown3Wrap.classList.contains('hidden') && countdown3El) {
        updateCountdown(FASE3_CLOSES_AT, { countdownEl: countdown3El, ids: { days: 'f3-days', hours: 'f3-hours', minutes: 'f3-minutes', seconds: 'f3-seconds' } });
      }
    }

    function run() { tick(); setInterval(tick, 1000); }
    if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', run);
    else run();
  })();
</script> 