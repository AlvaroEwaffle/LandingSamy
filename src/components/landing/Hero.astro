---

interface Props {
  title?: string;
  subtitle?: string;
}

const { 
  title = "El primer evento en Chile que transforma", 
  subtitle = "cómo grabas tu trabajo en camilla." 
} = Astro.props;

const carouselImages = [
  "/assets/january/Fotos_Camilla/IMG_4812.JPG",
  "/assets/january/Fotos/IMG_4808.JPG",
  "/assets/january/Fotos_Camilla/IMG_4817.JPG",
  "/assets/january/Fotos/IMG_4812.JPG",
  "/assets/january/Fotos_Camilla/IMG_4813.JPG",
  "/assets/january/Fotos/IMG_4817.JPG",
  "/assets/january/Fotos/IMG_6841.JPG",
  "/assets/january/Fotos/IMG_7404.JPG"
];
---

<!-- Fixed Payment Banner -->
<div class="fixed top-0 left-0 w-full bg-primary/90 backdrop-blur-sm z-50 transition-colors duration-300">
  <div class="flex items-center justify-center gap-2 md:gap-4 px-2 md:px-4 py-2 md:py-3 text-white font-semibold flex-nowrap">
    <span id="banner-phase-text" class="text-xs md:text-base whitespace-nowrap">
      Cargando fase...
    </span>
    <span id="banner-countdown" class="text-xs md:text-base font-extrabold tabular-nums whitespace-nowrap">
      00:00:00
    </span>
    <a 
      href="#inversion" 
      class="bg-white text-primary rounded-lg px-3 md:px-6 py-2 md:py-3 font-bold text-sm md:text-base hover:bg-white/90 transition-colors duration-300 whitespace-nowrap flex-shrink-0"
      onclick="event.preventDefault(); scrollToPlans();"
    >
      Empezar ya
    </a>
  </div>
</div>

<!-- Video Version (Desktop & Mobile) -->
<section class="relative h-[55vh] md:min-h-screen flex items-center justify-center bg-black overflow-hidden">
  <!-- Background Video -->
  <div class="absolute inset-0 w-full h-full overflow-hidden">
    <iframe
      src="https://www.youtube.com/embed/_Fby66icI2g?autoplay=1&mute=1&loop=1&playlist=_Fby66icI2g&controls=0&showinfo=0&rel=0&modestbranding=1&playsinline=1&disablekb=1&fs=0&iv_load_policy=3&cc_load_policy=0&autohide=1&enablejsapi=0&color=white&theme=dark"
      class="absolute top-0 left-1/2 -translate-x-1/2 w-[190%] h-full md:w-full md:h-full object-cover"
      frameborder="0"
      allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
      allowfullscreen
    ></iframe>
  </div>
</section>

<!-- Subtitle Section -->
<section class="bg-black py-8">
  <div class="max-w-4xl mx-auto px-4 text-center">
    <h2 class="text-2xl md:text-3xl font-bold text-white opacity-0 translate-y-8 transition-all duration-1000 ease-out" id="hero-title">
      UNA FORMACIÓN EN LÍNEA DE CREACIÓN DE VIDEOS EN CAMILLA
    </h2>
  </div>
</section>

<!-- S2 Image Carousel Section -->
<section class="relative w-full bg-black py-8">
  <!-- Powerful Quote -->
  <div class="text-center mb-8">
    <h2 class="text-xl md:text-2xl font-bold text-white px-4 opacity-0 translate-y-8 transition-all duration-1000 ease-out delay-300" id="hero-quote">
      Ya no se trata solo de tener una buena técnica, necesitas saber <span class="text-primary">cómo mostrarla</span>
    </h2>
  </div>
  
  <!-- Carousel Container -->
  <div class="relative overflow-hidden">
      <div class="flex animate-scroll-carousel" id="carousel">
        {/* Original images */}
        {carouselImages.map((image, index) => (
          <div class="w-1/3 flex-shrink-0">
            <img src={image} alt={`Carousel image ${index + 1}`} class="w-full h-80 md:h-[500px] object-cover" />
          </div>
        ))}
        {/* Duplicate images for seamless loop */}
        {carouselImages.map((image, index) => (
          <div class="w-1/3 flex-shrink-0">
            <img src={image} alt={`Carousel image ${index + 1}`} class="w-full h-80 md:h-[500px] object-cover" />
          </div>
        ))}
      </div>
    </div>
</section>



    <style>
      @keyframes scroll-banner {
        0% {
          transform: translateX(0);
        }
        100% {
          transform: translateX(-50%);
        }
      }
      
      .animate-scroll-banner {
        animation: scroll-banner 20s linear infinite;
      }
      
      @keyframes scroll-carousel {
        0% {
          transform: translateX(0);
        }
        100% {
          transform: translateX(-50%);
        }
      }
      
      .animate-scroll-carousel {
        animation: scroll-carousel 20s linear infinite;
      }

      /* Hide YouTube controls and UI elements */
      iframe[src*="youtube.com"] {
        position: relative;
      }

      /* Hide YouTube logo and controls overlay */
      iframe[src*="youtube.com"]::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        pointer-events: none;
        z-index: 1;
      }

    </style>

<script>
  // Function to scroll to plans section
  function scrollToPlans() {
    const plansSection = document.getElementById('inversion') || document.getElementById('planes');
    if (plansSection) {
      plansSection.scrollIntoView({
        behavior: 'smooth',
        block: 'start'
      });
    }
  }

  // Make function globally available
  (window as any).scrollToPlans = scrollToPlans;

  function pad2(n: number) {
    return String(n).padStart(2, '0');
  }

  function formatCountdown(ms: number) {
    const totalSeconds = Math.max(0, Math.floor(ms / 1000));
    const days = Math.floor(totalSeconds / 86400);
    const hours = Math.floor((totalSeconds % 86400) / 3600);
    const minutes = Math.floor((totalSeconds % 3600) / 60);
    const seconds = totalSeconds % 60;
    // If days > 0 we show D:HH:MM:SS, else HH:MM:SS
    if (days > 0) return `${days}d ${pad2(hours)}:${pad2(minutes)}:${pad2(seconds)}`;
    return `${pad2(hours)}:${pad2(minutes)}:${pad2(seconds)}`;
  }

  function getPhaseInfo(now = new Date()) {
    // Chile UTC-3 en feb. Fase 2: 07/02 21:59 → 08/02 12:00 Chile
    const PHASE2_START_AT = new Date('2026-02-08T00:59:00Z');
    const PHASE2_END_AT = new Date('2026-02-08T15:00:00Z');

    if (now >= PHASE2_START_AT && now < PHASE2_END_AT) return { phase: 2, endsAt: PHASE2_END_AT };
    return { phase: 'soldout' as const, endsAt: null as any };
  }

  function updateBannerCountdown() {
    const phaseTextEl = document.getElementById('banner-phase-text');
    const countdownEl = document.getElementById('banner-countdown');
    if (!phaseTextEl || !countdownEl) return;

    const info = getPhaseInfo(new Date());
    if (info.phase === 2) {
      phaseTextEl.textContent = 'Fase 2 cierra en';
      countdownEl.classList.remove('hidden');
      countdownEl.textContent = formatCountdown(info.endsAt.getTime() - Date.now());
      return;
    }

    phaseTextEl.textContent = 'SOLD OUT · Lista de espera abierta';
    countdownEl.classList.add('hidden');
  }

  // Intersection Observer for animations
  const observerOptions = {
    threshold: 0.1
  };

  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.remove('opacity-0', 'translate-y-8');
        entry.target.classList.add('opacity-100', 'translate-y-0');
      }
    });
  }, observerOptions);

  document.addEventListener('DOMContentLoaded', () => {
    const title = document.getElementById('hero-title');
    const quote = document.getElementById('hero-quote');
    if (title) observer.observe(title);
    if (quote) observer.observe(quote);

    updateBannerCountdown();
    setInterval(updateBannerCountdown, 1000);
  });
</script>