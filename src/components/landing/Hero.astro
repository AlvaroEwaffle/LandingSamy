---
import {
  getHeroBannerText,
  primaryBannerCtaLabel,
} from '../../data/offerPhases';

interface Props {
  title?: string;
  subtitle?: string;
}

const { 
  title = "El primer evento en Chile que transforma", 
  subtitle = "cómo grabas tu trabajo en camilla." 
} = Astro.props;

const carouselImages = [
  "/assets/january/Fotos_Camilla/IMG_4812.JPG",
  "/assets/january/Fotos/IMG_4808.JPG",
  "/assets/january/Fotos_Camilla/IMG_4817.JPG",
  "/assets/january/Fotos/IMG_4812.JPG",
  "/assets/january/Fotos_Camilla/IMG_4813.JPG",
  "/assets/january/Fotos/IMG_4817.JPG",
  "/assets/january/Fotos/IMG_6841.JPG",
  "/assets/january/Fotos/IMG_7404.JPG"
];

const bannerText = getHeroBannerText();
const bannerCtaHref = '#inversion';
const bannerCtaLabel = primaryBannerCtaLabel;
---

<div class="fixed top-0 left-0 z-50 w-full bg-primary shadow-[0_12px_30px_rgba(0,0,0,0.2)]">
  <div class="mx-auto flex max-w-7xl items-center gap-3 px-3 py-2 text-white md:gap-5 md:px-6 md:py-3">
    <div class="min-w-0 flex-1 overflow-hidden">
      <div class="flex w-max min-w-full animate-scroll-banner items-center gap-8 whitespace-nowrap pr-8">
        {Array.from({ length: 4 }).map(() => (
          <span class="text-[11px] font-extrabold uppercase tracking-[0.14em] md:text-sm">
            {bannerText}
          </span>
        ))}
      </div>
    </div>
    <div class="shrink-0">
      <a
        href={bannerCtaHref}
        class="inline-flex min-h-11 items-center justify-center rounded-md bg-white px-3 py-2 text-[11px] font-black uppercase tracking-[0.12em] text-primary transition-colors duration-300 hover:bg-white/90 md:px-5 md:text-sm"
        onclick="event.preventDefault(); scrollToPlans();"
      >
        {bannerCtaLabel}
      </a>
    </div>
  </div>
</div>

<!-- Video Version (Desktop & Mobile) -->
<section class:list={[
  'relative flex h-[55vh] items-center justify-center overflow-hidden bg-black',
  'mt-14 md:mt-16 md:min-h-[calc(100vh-4rem)]',
]}>
  <!-- Background Video -->
  <div class="hero-video-shell absolute inset-0 w-full h-full overflow-hidden" data-hero-video-shell>
    <iframe
      id="hero-video-iframe"
      src="https://www.youtube.com/embed/_Fby66icI2g?autoplay=1&mute=1&loop=1&playlist=_Fby66icI2g&controls=0&showinfo=0&rel=0&modestbranding=1&playsinline=1&disablekb=1&fs=0&iv_load_policy=3&cc_load_policy=0&autohide=1&enablejsapi=0&color=white&theme=dark"
      class="hero-video-frame absolute top-0 left-1/2 h-full w-[190%] -translate-x-1/2 object-cover md:h-full md:w-full"
      frameborder="0"
      allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
      allowfullscreen
      loading="eager"
    ></iframe>
    <div class="hero-video-overlay" data-hero-video-overlay>
      <div class="hero-video-poster"></div>
      <div class="hero-video-vignette"></div>
      <div class="hero-video-loader">
        <p class="hero-video-kicker">IMPACTO VISUAL ONLINE</p>
        <div class="hero-video-loader-track">
          <span class="hero-video-loader-bar"></span>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Subtitle Section -->
<section class="bg-black py-8">
  <div class="max-w-4xl mx-auto px-4 text-center">
    <h2 class="text-2xl md:text-4xl font-bold text-white opacity-0 translate-y-8 transition-all duration-1000 ease-out" id="hero-title">
      APRENDE A GRABAR CONTENIDO PROFESIONAL EN CAMILLA USANDO SOLO TU CELULAR
    </h2>
    <p class="mt-4 text-base md:text-xl text-white/80 leading-relaxed opacity-0 translate-y-8 transition-all duration-1000 ease-out delay-200" id="hero-description">
      Para que te vean como una marca de alto nivel, atraigas mejores clientes y puedas cobrar más por tu trabajo.
    </p>
  </div>
</section>

<!-- S2 Image Carousel Section -->
<section class="relative w-full bg-black py-8">
  <!-- Powerful Quote -->
  <div class="text-center mb-8">
    <h2 class="text-xl md:text-2xl font-bold text-white px-4 opacity-0 translate-y-8 transition-all duration-1000 ease-out delay-300" id="hero-quote">
      Ya no se trata solo de tener una buena técnica, necesitas saber <span class="text-primary">cómo mostrarla</span>
    </h2>
  </div>
  
  <!-- Carousel Container -->
  <div class="relative overflow-hidden">
      <div class="flex animate-scroll-carousel" id="carousel">
        {/* Original images */}
        {carouselImages.map((image, index) => (
          <div class="w-1/3 flex-shrink-0">
            <img src={image} alt={`Carousel image ${index + 1}`} class="w-full h-80 md:h-[500px] object-cover" />
          </div>
        ))}
        {/* Duplicate images for seamless loop */}
        {carouselImages.map((image, index) => (
          <div class="w-1/3 flex-shrink-0">
            <img src={image} alt={`Carousel image ${index + 1}`} class="w-full h-80 md:h-[500px] object-cover" />
          </div>
        ))}
      </div>
    </div>
</section>



    <style>
      @keyframes scroll-banner {
        0% {
          transform: translateX(0);
        }
        100% {
          transform: translateX(-25%);
        }
      }
      
      .animate-scroll-banner {
        animation: scroll-banner 16s linear infinite;
      }
      
      @keyframes scroll-carousel {
        0% {
          transform: translateX(0);
        }
        100% {
          transform: translateX(-50%);
        }
      }
      
      .animate-scroll-carousel {
        animation: scroll-carousel 20s linear infinite;
      }

      .hero-video-shell {
        background: #000;
      }

      .hero-video-frame {
        opacity: 0;
        filter: blur(18px) saturate(0.8);
        transform: translateX(-50%) scale(1.06);
        transition:
          opacity 1200ms ease,
          filter 1400ms ease,
          transform 1400ms ease;
      }

      .hero-video-overlay {
        position: absolute;
        inset: 0;
        z-index: 2;
        overflow: hidden;
        pointer-events: none;
        transition:
          opacity 900ms ease,
          visibility 900ms ease;
      }

      .hero-video-poster {
        position: absolute;
        inset: 0;
        background:
          linear-gradient(180deg, rgba(0, 0, 0, 0.18) 0%, rgba(0, 0, 0, 0.72) 100%),
          radial-gradient(circle at 50% 50%, rgba(210, 32, 31, 0.16) 0%, rgba(210, 32, 31, 0) 58%),
          #000;
        animation: hero-poster-scale 2400ms ease forwards;
      }

      .hero-video-vignette {
        position: absolute;
        inset: 0;
        background:
          linear-gradient(90deg, rgba(0, 0, 0, 0.78) 0%, rgba(0, 0, 0, 0.08) 18%, rgba(0, 0, 0, 0.08) 82%, rgba(0, 0, 0, 0.78) 100%),
          linear-gradient(180deg, rgba(0, 0, 0, 0.82) 0%, rgba(0, 0, 0, 0.04) 22%, rgba(0, 0, 0, 0.04) 78%, rgba(0, 0, 0, 0.82) 100%);
      }

      .hero-video-loader {
        position: absolute;
        left: 50%;
        top: 50%;
        width: min(78vw, 24rem);
        transform: translate(-50%, -50%);
        text-align: center;
      }

      .hero-video-kicker {
        margin: 0;
        color: rgba(255, 255, 255, 0.86);
        text-transform: uppercase;
      }

      .hero-video-kicker {
        font-size: 0.72rem;
        font-weight: 800;
        letter-spacing: 0.42em;
      }

      .hero-video-loader-track {
        position: relative;
        margin-top: 1rem;
        height: 2px;
        overflow: hidden;
        background: rgba(255, 255, 255, 0.18);
      }

      .hero-video-loader-bar {
        position: absolute;
        inset: 0;
        width: 42%;
        background: linear-gradient(90deg, rgba(210, 32, 31, 0) 0%, rgba(210, 32, 31, 1) 52%, rgba(255, 255, 255, 0.9) 100%);
        box-shadow: 0 0 22px rgba(210, 32, 31, 0.65);
        animation: hero-loader-sweep 1.4s ease-in-out infinite;
      }

      .hero-video-shell.is-loaded .hero-video-frame {
        opacity: 1;
        filter: blur(0) saturate(1);
        transform: translateX(-50%) scale(1);
      }

      .hero-video-shell.is-loaded .hero-video-overlay {
        opacity: 0;
        visibility: hidden;
      }

      @keyframes hero-loader-sweep {
        0% {
          transform: translateX(-140%);
        }
        100% {
          transform: translateX(340%);
        }
      }

      @keyframes hero-poster-scale {
        0% {
          transform: scale(1.08);
          filter: blur(0);
        }
        100% {
          transform: scale(1);
          filter: blur(1px);
        }
      }

      /* Hide YouTube controls and UI elements */
      iframe[src*="youtube.com"] {
        position: relative;
      }

      /* Hide YouTube logo and controls overlay */
      iframe[src*="youtube.com"]::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        pointer-events: none;
        z-index: 1;
      }

      @media (prefers-reduced-motion: reduce) {
        .hero-video-frame,
        .hero-video-overlay,
        .hero-video-poster,
        .hero-video-loader-bar {
          animation: none;
          transition: none;
        }
      }

    </style>

<script>
  // Function to scroll to plans section
  function scrollToPlans() {
    const plansSection = document.getElementById('inversion') || document.getElementById('planes');
    if (plansSection) {
      plansSection.scrollIntoView({
        behavior: 'smooth',
        block: 'start'
      });
    }
  }

  // Make function globally available
  (window as any).scrollToPlans = scrollToPlans;

  function markHeroVideoReady() {
    const shell = document.querySelector('[data-hero-video-shell]');
    if (!(shell instanceof HTMLElement) || shell.classList.contains('is-loaded')) {
      return;
    }

    shell.classList.add('is-loaded');
  }

  // Intersection Observer for animations
  const observerOptions = {
    threshold: 0.1
  };

  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.remove('opacity-0', 'translate-y-8');
        entry.target.classList.add('opacity-100', 'translate-y-0');
      }
    });
  }, observerOptions);

  document.addEventListener('DOMContentLoaded', () => {
    const title = document.getElementById('hero-title');
    const description = document.getElementById('hero-description');
    const quote = document.getElementById('hero-quote');
    const iframe = document.getElementById('hero-video-iframe');
    if (title) observer.observe(title);
    if (description) observer.observe(description);
    if (quote) observer.observe(quote);

    if (iframe instanceof HTMLIFrameElement) {
      iframe.addEventListener('load', markHeroVideoReady, { once: true });
    }

    window.setTimeout(markHeroVideoReady, 2400);
  });
</script>
