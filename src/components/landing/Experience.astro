---
import {
  totalTrainingValueUsd,
  trainingItems,
} from '../../data/offerPhases';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Lo que recibes en este Entrenamiento 360',
  description = 'Cada módulo te muestra qué grabar, cómo grabarlo y cómo convertir ese contenido en una marca que atraiga más clientes y te haga destacar en tu rubro.',
} = Astro.props;
---

<section id="experiencia" class="relative overflow-hidden bg-black py-20">
  <div class="absolute inset-0 z-0">
    <img
      src="/assets/Experiencia.png"
      alt="Experience background"
      class="h-full w-full object-cover"
    />
    <div class="absolute inset-0 bg-black/70"></div>
  </div>

  <div class="relative z-10 mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="mb-16 text-center">
      <p class="mb-4 text-sm font-semibold uppercase tracking-[0.35em] text-primary/90 md:text-base">
        Entrenamiento 360
      </p>
      <h2 class="mx-auto mb-6 max-w-4xl text-3xl font-bold text-white md:text-4xl lg:text-5xl">
        {title}
      </h2>
      <p class="mx-auto max-w-3xl text-xl leading-relaxed text-white/80">
        {description}
      </p>
    </div>

    <div class="space-y-4">
      <div class="grid grid-cols-1 gap-4">
        {trainingItems.map((item, index) => (
          <div
            class="fade-in rounded-[1.5rem] border border-white/15 bg-white/5 px-5 py-5 shadow-[0_18px_40px_rgba(0,0,0,0.22)] backdrop-blur-sm md:px-6"
            style={`transition-delay: ${index * 0.08}s`}
          >
            <div class="flex items-start gap-4">
              <span class="mt-1 inline-flex h-3 w-3 shrink-0 rounded-full bg-primary"></span>
              <p class="text-[13px] leading-relaxed text-white sm:text-sm md:text-base">
                <span class="font-black text-white">{item.title}:</span>{' '}
                <span class="text-white">{item.description}</span>
              </p>
            </div>
          </div>
        ))}
      </div>
    </div>

    <div class="fade-in mt-10 rounded-[2rem] border border-primary/25 bg-black/70 p-8 text-center shadow-[0_20px_60px_rgba(210,32,31,0.18)]">
      <p class="mx-auto max-w-3xl text-base leading-relaxed text-white/80 md:text-lg">
        Si sumamos cada una de estas herramientas por separado, el valor total de este entrenamiento es de
      </p>
      <p class="mt-5 text-5xl font-black tracking-tight text-primary line-through decoration-4 decoration-primary/90 md:text-7xl">
        ${totalTrainingValueUsd} USD
      </p>
      <p class="mt-4 text-sm uppercase tracking-[0.28em] text-white/60 md:text-base">
        Valor real del entrenamiento
      </p>
    </div>
  </div>
</section>
