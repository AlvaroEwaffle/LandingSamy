---
interface Props {
  title?: string;
  description?: string;
}

const { 
  title = "¿Qué incluye esta formación?", 
  description = "Acceso inmediato a todo el contenido grabado por módulos, donde aprenderás paso a paso." 
} = Astro.props;

const experiences = [
  {
    icon: "📹",
    title: "Grabar contenido profesional",
    description: "Aprende a grabar contenido profesional para tu negocio usando solo tu celular."
  },
  {
    icon: "🛠️",
    title: "Usar herramientas correctamente",
    description: "Usa correctamente las herramientas necesarias en cabina: celular, luces y trípode."
  },
  {
    icon: "📸",
    title: "Grabar desde diferentes ángulos",
    description: "Aprende a grabar desde diferentes ángulos para potenciar tu trabajo."
  },
  {
    icon: "🎬",
    title: "Aplicar el método exacto",
    description: "Aplica el método exacto que utilizo para crear mejores videos."
  },
  {
    icon: "✂️",
    title: "Editar con CapCut",
    description: "Edita de forma fácil y efectiva con CapCut."
  },
  {
    icon: "📚",
    title: "Material de apoyo",
    description: "Acceso a plantillas, PDFs, guías y material de apoyo."
  }
];
---

<section id="experiencia" class="py-20 bg-black relative overflow-hidden">
  <!-- Background Image -->
  <div class="absolute inset-0 z-0">
    <img 
      src="/assets/Experiencia.png" 
      alt="Experience background" 
      class="w-full h-full object-cover"
    />
    <!-- Dark overlay for better text readability -->
    <div class="absolute inset-0 bg-black/60"></div>
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <!-- Section Header -->
    <div class="text-center mb-16">
      <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold text-white mb-6">
        {title}
      </h2>
      <p class="text-xl text-white/80 max-w-3xl mx-auto leading-relaxed">
        {description}
      </p>
    </div>

    <!-- Experience Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-16">
      {experiences.map((experience, index) => (
        <div 
          class="bg-black/80 backdrop-blur-sm rounded-2xl p-6 shadow-lg hover:shadow-xl transition-all duration-300 transform hover:-translate-y-2 border border-primary/20 fade-in"
          style={`animation-delay: ${index * 0.1}s`}
        >
          <div class="text-center">
            <!-- Icon and Title -->
            <div class="flex flex-col items-center mb-3">
              <span class="text-3xl mb-2">{experience.icon}</span>
              <h3 class="text-lg font-bold text-white">
                {experience.title}
              </h3>
            </div>
            
            <!-- Description -->
            <p class="text-white/80 leading-relaxed text-sm">
              {experience.description}
            </p>
          </div>
        </div>
      ))}
    </div>

    <!-- Additional Features -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center mb-16">
      <!-- Left: Features List -->
      <div class="space-y-6">
        <h3 class="text-2xl font-bold text-white mb-6">
          Además incluye:
        </h3>
        
        <div class="space-y-4">
          <div class="flex items-center">
            <div class="w-6 h-6 bg-primary rounded-full flex items-center justify-center mr-4">
              <svg class="w-3 h-3 text-white" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
              </svg>
            </div>
            <span class="text-white font-medium">Acceso inmediato a todo el contenido</span>
          </div>
          
          <div class="flex items-center">
            <div class="w-6 h-6 bg-primary rounded-full flex items-center justify-center mr-4">
              <svg class="w-3 h-3 text-white" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
              </svg>
            </div>
            <span class="text-white font-medium">6 meses de acceso a la plataforma</span>
          </div>
          
          <div class="flex items-center">
            <div class="w-6 h-6 bg-primary rounded-full flex items-center justify-center mr-4">
              <svg class="w-3 h-3 text-white" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
              </svg>
            </div>
            <span class="text-white font-medium">Soporte del equipo durante 6 meses</span>
          </div>
          
          <div class="flex items-center">
            <div class="w-6 h-6 bg-primary rounded-full flex items-center justify-center mr-4">
              <svg class="w-3 h-3 text-white" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
              </svg>
            </div>
            <span class="text-white font-medium">Acompañamiento directo con Samy por 30 días en WhatsApp</span>
          </div>
          
          <div class="flex items-center">
            <div class="w-6 h-6 bg-primary rounded-full flex items-center justify-center mr-4">
              <svg class="w-3 h-3 text-white" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
              </svg>
            </div>
            <span class="text-white font-medium">Avanzas a tu ritmo, sin depender de horarios</span>
          </div>
        </div>
      </div>

      <!-- Right: Visual Content -->
      <div class="relative">
        <div class="bg-gradient-to-br from-primary/10 to-red-900/20 rounded-2xl p-8 text-center backdrop-blur-sm">
          <div class="w-24 h-24 bg-primary rounded-full flex items-center justify-center mx-auto mb-6">
            <svg class="w-12 h-12 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.746 0 3.332.477 4.5 1.253v13C19.832 18.477 18.246 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"></path>
            </svg>
          </div>
          <h4 class="text-xl font-bold text-white mb-2">
            Contenido organizado
          </h4>
          <p class="text-white/80 mb-6">
            Módulos grabados con explicación paso a paso
          </p>
        </div>
      </div>
    </div>

    
  </div>
</section> 