---
interface Props {
  title?: string;
}

const { 
  title = "Todo lo que necesitas saber" 
} = Astro.props;

const faqs = [
  {
    question: "¿Dónde veo la formación? ¿Es en vivo o grabada?",
    answer: "Es una formación 100% grabada, organizada por módulos y con explicación paso a paso. Accedes online y avanzas a tu ritmo, sin depender de horarios."
  },
  {
    question: "¿Por cuánto tiempo tendré acceso al material?",
    answer: "Tendrás acceso por 6 meses desde la fecha en que ingresas a la plataforma."
  },
  {
    question: "Estoy iniciando, ¿puedo tomarla igual?",
    answer: "Sí. Si hoy estás empezando, esta formación te guía desde cero y paso a paso para que sepas qué grabar, cómo grabarlo y cómo editarlo sin complicarte."
  },
  {
    question: "¿Tendré soporte si me surgen dudas?",
    answer: "Sí. Tendrás acceso a la formación y soporte de nuestro equipo durante 6 meses. Y además, como bonus, tendrás acompañamiento directo conmigo (Samy) por 30 días dentro del grupo de WhatsApp para todos los participantes."
  },
  {
    question: "Me sirve si soy manicurista?",
    answer: "Esta formación es exclusiva para artistas que trabajan en camilla. Si tu servicio no se realiza en camilla, probablemente no sea la mejor opción para ti."
  }
];
---

<section id="faq" class="py-20 bg-black relative overflow-hidden">
  <!-- Background Image from january folder -->
  <div class="absolute inset-0 z-0">
    <img 
      src="/assets/january/Fotos/IMG_4812.JPG" 
      alt="Background" 
      class="w-full h-full object-cover opacity-20"
    />
    <div class="absolute inset-0 bg-black/70"></div>
  </div>

  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <!-- Section Header -->
    <div class="text-center mb-16">
      <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold text-white mb-6">
        {title}
      </h2>
    </div>

    <!-- FAQ Accordion -->
    <div class="space-y-4">
      {faqs.map((faq, index) => (
        <div 
          class="bg-black/80 backdrop-blur-sm rounded-2xl border border-primary/20 overflow-hidden fade-in"
          style={`animation-delay: ${index * 0.1}s`}
        >
          <button
            class="w-full px-6 py-4 text-left flex items-center justify-between hover:bg-primary/10 transition-colors duration-300"
            onclick={`toggleFAQ(${index})`}
            id={`faq-button-${index}`}
          >
            <h3 class="text-lg md:text-xl font-semibold text-white pr-4">
              {faq.question}
            </h3>
            <svg 
              class="w-6 h-6 text-primary flex-shrink-0 transform transition-transform duration-300"
              id={`faq-icon-${index}`}
              fill="none" 
              stroke="currentColor" 
              viewBox="0 0 24 24"
            >
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
            </svg>
          </button>
          <div 
            class="hidden px-6 pb-4"
            id={`faq-answer-${index}`}
          >
            <p class="text-white/80 leading-relaxed">
              {faq.answer}
            </p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  function toggleFAQ(index: number) {
    const answer = document.getElementById(`faq-answer-${index}`);
    const icon = document.getElementById(`faq-icon-${index}`);
    
    if (answer && icon) {
      const isHidden = answer.classList.contains('hidden');
      
      // Close all other FAQs
      for (let i = 0; i < 5; i++) {
        const otherAnswer = document.getElementById(`faq-answer-${i}`);
        const otherIcon = document.getElementById(`faq-icon-${i}`);
        if (otherAnswer && otherIcon && i !== index) {
          otherAnswer.classList.add('hidden');
          otherIcon.classList.remove('rotate-180');
        }
      }
      
      // Toggle current FAQ
      if (isHidden) {
        answer.classList.remove('hidden');
        icon.classList.add('rotate-180');
      } else {
        answer.classList.add('hidden');
        icon.classList.remove('rotate-180');
      }
    }
  }
  
  // Make function globally available
  (window as any).toggleFAQ = toggleFAQ;
</script>
