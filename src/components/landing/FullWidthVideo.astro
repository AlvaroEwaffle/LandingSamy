---
interface Props {
  videoId?: string;
}

const { 
  videoId = "OCu-5fmS_mI" 
} = Astro.props;
---

<section class="relative flex flex-col items-center justify-center bg-black overflow-hidden py-10">
  <div class="max-w-4xl mx-auto px-4 text-center mb-8">
    <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold text-white">
      Aquí te cuento más
    </h2>
  </div>
  
  <div class="relative w-full h-[60vh] md:h-[80vh] overflow-hidden">
    <!-- Background Video -->
    <div class="absolute inset-0 w-full h-full overflow-hidden">
      <iframe
        src={`https://www.youtube.com/embed/${videoId}?autoplay=0&mute=0&loop=1&playlist=${videoId}&controls=1&showinfo=0&rel=0&playsinline=1&fs=1&iv_load_policy=3&cc_load_policy=0&autohide=1&enablejsapi=0&color=white&theme=dark`}
        class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[150%] h-[150%] md:w-full md:h-full object-cover"
        frameborder="0"
        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
        allowfullscreen
      ></iframe>
    </div>
  </div>
</section>
