---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Impacto Visual | Formación online de creación de videos en camilla",
  description = "Formación online para profesionales de la belleza que quieren elevar su contenido. Aprende el método SAMY, grabación con celular, encuadres y ángulos profesionales. Acceso inmediato.",
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, "https://impactovisual.cl");

const socialImageURL = new URL("/assets/january/Fotos/IMG_9259.jpg", canonicalURL);

const keywords = [
  "impacto visual",
  "formación online belleza",
  "grabación camilla",
  "contenido profesional",
  "método samy",
  "fotografía belleza",
  "video profesional",
  "marca personal",
  "redes sociales",
  "instagram",
  "tiktok",
  "chile",
  "curso online",
  "formación belleza",
  "hotmart",
  "capcut",
];
---

<!doctype html>
<html lang="es">
  <head>
    <!-- Google Tag Manager -->
    <script is:inline>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
    new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
    j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
    'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
    })(window,document,'script','dataLayer','GTM-NJRS5LHT');</script>
    <!-- End Google Tag Manager -->

    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/png" href="/assets/Logo.png" />
    <link rel="canonical" href={canonicalURL} />
    <meta name="generator" content={Astro.generator} />

    <!-- Primary Meta Tags -->
    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />
    <meta name="keywords" content={keywords.join(", ")} />
    <meta name="author" content="Impacto Visual" />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={socialImageURL} />
    <meta property="og:locale" content="es_ES" />
    <meta property="og:site_name" content="Impacto Visual" />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={canonicalURL} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={socialImageURL} />

    <!-- Additional Meta Tags -->
    <meta name="robots" content="index, follow" />
    <meta name="googlebot" content="index, follow" />
    <meta name="theme-color" content="#d2201f" />
    <meta name="format-detection" content="telephone=no" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black" />
    <meta name="apple-mobile-web-app-title" content="Impacto Visual" />
    
    <!-- Language and Region -->
    <meta name="language" content="Spanish" />
    <meta name="geo.region" content="CL" />
    <meta name="geo.placename" content="Santiago" />
    
    <!-- Additional SEO -->
    <meta name="revisit-after" content="7 days" />
    <meta name="distribution" content="global" />
    <meta name="rating" content="general" />
    <meta name="coverage" content="worldwide" />
    <meta name="target" content="all" />

    <!-- Structured Data / JSON-LD -->
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@graph": [
          {
            "@type": "Course",
            "name": "Impacto Visual",
            "description": "Formación online de creación de videos en camilla. Aprende el método SAMY para profesionales de la belleza.",
            "provider": {
              "@type": "Organization",
              "name": "Impacto Visual",
              "url": "https://impactovisual.cl"
            },
            "instructor": {
              "@type": "Person",
              "name": "Samy",
              "description": "Experta en contenido visual para profesionales de la belleza"
            },
            "offers": {
              "@type": "Offer",
              "price": "147",
              "priceCurrency": "USD",
              "availability": "https://schema.org/InStock"
            },
            "courseMode": "online"
          },
          {
            "@type": "Organization",
            "name": "Impacto Visual",
            "url": "https://impactovisual.cl",
            "description": "Formación online para profesionales de la belleza que quieren elevar su contenido visual.",
            "sameAs": [
              "https://www.instagram.com/impactovisual/",
              "https://www.tiktok.com/@impactovisual"
            ],
            "address": {
              "@type": "PostalAddress",
              "addressLocality": "Santiago",
              "addressRegion": "RM",
              "addressCountry": "CL"
            }
          }
        ]
      }
    </script>

    <!-- Google Fonts - Montserrat -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">

    <!-- Remix Icons -->
    <link
      href="https://cdn.jsdelivr.net/npm/remixicon@3.5.0/fonts/remixicon.css"
      rel="stylesheet"
    />

    <!-- Social Media Links -->
    <link rel="me" href="https://www.instagram.com/impactovisual/" />
    <link rel="me" href="https://www.tiktok.com/@impactovisual" />

    <!-- AOS Animate On Scroll CSS -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/aos@2.3.4/dist/aos.css" />
  </head>
  <body class="overflow-x-hidden">
    <!-- Google Tag Manager (noscript) -->
    <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-NJRS5LHT"
    height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
    <!-- End Google Tag Manager (noscript) -->
    <slot />


    <!-- AOS Animate On Scroll JS -->
    <script src="https://cdn.jsdelivr.net/npm/aos@2.3.4/dist/aos.js" defer></script>
    <script is:inline>
      window.addEventListener('DOMContentLoaded', function () {
        if (window.AOS) {
          window.AOS.init({
            duration: 800,
            once: true
          });
        }
        
        // Intersection Observer for fade-in animations
        const observerOptions = {
          threshold: 0.1,
          rootMargin: '0px 0px -50px 0px'
        };

        const observer = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              entry.target.classList.add('visible');
            }
          });
        }, observerOptions);

        // Observe all fade-in elements
        document.querySelectorAll('.fade-in').forEach(el => {
          observer.observe(el);
        });
        
        // Enhanced smooth scrolling for anchor links
        document.querySelectorAll('a[href^="#"]').forEach(anchor => {
          anchor.addEventListener('click', function (e) {
            e.preventDefault();
            const target = document.querySelector(this.getAttribute('href'));
            if (target) {
              target.scrollIntoView({
                behavior: 'smooth',
                block: 'start'
              });
            }
          });
        });
      });
    </script>
  </body>
</html>

<style>
  html,
  body {
    margin: 0;
    width: 100%;
    height: 100%;
  }
</style>
